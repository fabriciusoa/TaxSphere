# JWT Secret - Use uma string longa e aleatória em produção
JWT_SECRET=4124920d8c92260fd9fac04834c31075d716578b46d28f5ecba728b459cba630

# Ambiente (development | production)
# Em production:
#   - cookies terão Secure=true (exige HTTPS) e SameSite=Strict
#   - CORS desativado (frontend servido pelo próprio Express)
#   - frontend compilado servido de web/frontend/dist/
NODE_ENV=development

# Porta do servidor
PORT=3000

# Banco de dados — Supabase (PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE
# SUPABASE
DATABASE_URL=postgresql://postgres.fjfadqvhjxwzbpjkhyya:taxsphere@2026@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
# Banco de dados — Local Docker (PostgreSQL)
DATABASE_URL_LOCAL=postgresql://postgres:123@localhost:5432/postgres
# Se for Local, use DATABASE_URL_LOCAL; se for supabase, use DATABASE_URL
DATABASE_ENV=local

#Nome do servidor (opcional)
SERVER_NAME=localhost

#Localização da pasta de logs do backend
LOGS_PATH=../logs/
# ── HashiCorp Vault (encryption-as-a-service para .pfx + senhas) ─────────────
# Quando VAULT_ENABLED=true, certificadoService grava/lê cifrados via Vault Transit.
# Veja infra/vault/README.md para subir Vault local e gerar role_id/secret_id.
VAULT_ENABLED=false
VAULT_ADDR=http://127.0.0.1:8200
# VAULT_NAMESPACE=          # opcional (Vault Enterprise/HCP)
VAULT_TRANSIT_KEY=taxsphere-cert
VAULT_TRANSIT_PATH=transit
VAULT_ROLE_ID=
VAULT_SECRET_ID=
# DEV ONLY — em produção use TLS válido e deixe esta var em branco / false
VAULT_TLS_SKIP_VERIFY=false
# Se Vault cair: true = cai pra AES local (dev); false = falha fechada (prod)
VAULT_FALLBACK_AES=true
