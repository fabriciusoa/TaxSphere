# JWT Secret - Use uma string longa e aleatória em produção
JWT_SECRET=4124920d8c92260fd9fac04834c31075d716578b46d28f5ecba728b459cba630

# Ambiente (development | production)
# Em production:
#   - cookies terão Secure=true (exige HTTPS) e SameSite=Strict
#   - CORS desativado (frontend servido pelo próprio Express)
#   - frontend compilado servido de web/frontend/dist/
NODE_ENV=development

# Porta do servidor
PORT=3000

# Banco de dados — Supabase (PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

#Nome do servidor (opcional)
SERVER_NAME=localhost

#Localização da pasta de logs do backend
LOGS_PATH=../logs/